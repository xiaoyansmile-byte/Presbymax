{
  "name": "@prosbymax/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port ${PORT:-3001}",
    "build": "next build",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:init": "node scripts/init-db.js",
    "db:init:postgres": "node scripts/init-postgres.js",
    "db:migrate:postgres": "node scripts/migrate-to-postgres.js",
    "smoke:db": "node scripts/smoke-db.js",
    "test:smoke": "node --test scripts/smoke-domain.test.cjs",
    "test:api": "node --test scripts/smoke-api.test.cjs"
  },
  "dependencies": {
    "@prosbymax/core": "workspace:*",
    "@prosbymax/types": "workspace:*",
    "@prosbymax/ui": "workspace:*",
    "better-sqlite3": "^12.9.0",
    "clsx": "^2.1.1",
    "next": "^15.3.1",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.25.1",
    "eslint-config-next": "^15.3.1",
    "node-gyp": "^12.3.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
